VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/neoflow-contact

# Web Push (VAPID) — generate with: node scripts/generate-vapid-keys.js
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-base64url
# Supabase secrets (never expose client-side):
# supabase secrets set VAPID_PUBLIC_KEY=<same public key>
# supabase secrets set VAPID_PRIVATE_KEY=<your vapid private key>
# supabase secrets set VAPID_SUBJECT=mailto:contact@yourdomain.com

# Telegram: stocker en secrets Supabase (jamais côté client)
# supabase secrets set TELEGRAM_BOT_TOKEN=xxx
# supabase secrets set TELEGRAM_CHAT_ID=xxx
